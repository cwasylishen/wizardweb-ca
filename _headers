# WizardWeb.ca - Edge headers

# Favicon and logo SVGs: 30 days
/favicon.svg
  Cache-Control: public, max-age=2592000

# Images: 30 days
/assets/images/*
  Cache-Control: public, max-age=2592000

# HTML: 1 hour, must-revalidate so updates show quickly
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/
  Cache-Control: public, max-age=3600, must-revalidate

# CMS sandbox: keep out of search results, short cache
/admin/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: public, max-age=300

# Editor content seeds: not for search, not for visitors
/content/*
  X-Robots-Tag: noindex, nofollow

# Security headers on every response
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
